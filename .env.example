# Copy to `.env` and fill in only if you enable the matching optional backend.
# The default local path (llm.backend: auto -> deterministic offline engine) needs NONE of these.

# Optional: OpenRouter cloud fallback (config: llm.backend: openrouter). Never commit a real key.
OPENROUTER_API_KEY=

# Optional: Ollama host override (defaults to http://localhost:11434)
OLLAMA_HOST=

# Optional: Redis session cache (config: memory.session_backend: redis)
REDIS_URL=
